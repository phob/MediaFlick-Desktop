<component type="desktop-application">
  <id>io.github.phob.MediaFlickDesktop</id>
  <name>MediaFlick Desktop</name>
  <summary>External mpv playback for Jellyfin</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-2.0-or-later</project_license>
  <description>
    <p>
      MediaFlick Desktop is a lightweight desktop client for Jellyfin media servers.
      It embeds Jellyfin Web in a native CEF window and hands direct-play media
      streams to an external mpv process while reporting playback progress back
      to Jellyfin.
    </p>
  </description>
